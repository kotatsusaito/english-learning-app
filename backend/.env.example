# AI Service Configuration
# Choose either OpenAI or Claude by setting the appropriate API key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=500

# Claude Configuration (Alternative to OpenAI)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_TEMPERATURE=0.7
CLAUDE_MAX_TOKENS=500

# Choose which AI service to use: 'openai' or 'claude'
AI_SERVICE=openai

# Text-to-Speech Configuration
# OpenAI TTS API (uses same OPENAI_API_KEY as above)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
AUDIO_DIR=./audio
